# SiliconDev environment variables
# Copy to .env and adjust as needed.

# Auth token shared between Electron and the backend.
# Set automatically when launched via the desktop app.
# Leave unset for dev mode (auth disabled).
SILICON_AUTH_TOKEN=

# PID of the Electron parent process.
# Backend polls every 5s and exits when the parent is gone.
# Set automatically by Electron — no need to touch this.
SILICON_PARENT_PID=

# HuggingFace repo for the MLX embeddings model used by RAG search.
# Default: mlx-community/nomic-embed-text-v1.5-mlx
SILICONDEV_MLX_EMBEDDINGS_REPO=mlx-community/nomic-embed-text-v1.5-mlx
